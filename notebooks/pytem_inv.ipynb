   "id": "53136dc4",
   "metadata": {},
   "outputs": [],
   "source": [
    "def getR(resistivities, damp=1e-4):\n",
    "    \"\"\"First-order roughness (smoothness) matrix with Tikhonov damping.\n",
    "\n",
    "    Builds D^T D where D is the (N-1) x N first-difference operator, then\n",
    "    adds a small diagonal damp*I to ensure positive definiteness.\n",
    "    \"\"\"\n",
    "    n = resistivities.size\n",
    "    D = np.zeros((n - 1, n))\n",
    "    for k in range(n - 1):\n",
    "        D[k, k] = -1.0\n",
    "        D[k, k + 1] = 1.0\n",
    "    return D.T @ D + damp * np.eye(n)\n",
    "\n",
    "\n",
    "def getRMS(obs_data, mod_data, obs_noise):\n",
    "    \"\"\"Normalised root-mean-square data misfit.\"\"\"\n",
    "    return np.sqrt(np.mean(((mod_data - obs_data) / obs_noise) ** 2))\n",
    "\n",
    "\n",
    "def getAlpha(alpha_start, step):\n",
    "    \"\"\"Log-spaced regularisation parameter cooled by *step* decades/9.\"\"\"\n",
    "    return 10 ** (np.log10(alpha_start) - step / 9)\n",
    "\n",
    "\n",
    "def getAlphas(alpha, thicknesses):\n",
    "    \"\"\"Depth-weighted per-layer regularisation vector.\n",
    "\n",
    "    Scales alpha by the inverse of layer midpoint spacing so thin near-\n",
    "    surface layers are not over-penalised relative to thick deep layers.\n",
    "    \"\"\"\n",
    "    thicknesses = np.asarray(thicknesses)\n",
    "    tops = np.cumsum(np.concatenate(([0], thicknesses[:-1])))\n",
    "    midpoints = tops + thicknesses / 2.0\n",
    "    del_z = np.diff(midpoints)\n",
    "    w = np.empty(len(del_z) + 1)\n",
    "    w[0] = 1.0 / del_z[0]\n",
    "    w[1:-1] = 1.0 / del_z[:-1] + 1.0 / del_z[1:]\n",
    "    w[-1] = 1.0 / del_z[-1]\n",
    "    return alpha * w\n",
    "\n",
    "\n",
    "def getJ(thicknesses, log_resistivities, tx_geom, times,\n",
    "         use_numba=False, use_cuda=True, eps=1e-4, fwd=tem_forward_circle,\n",
    "         transform='dlf', hankel_filter='key_101', fourier_filter='key_101',\n",
    "         euler_order=11):\n",
    "    \"\"\"Finite-difference Jacobian d(ln(-dBdt_i)) / d(ln rho_j).\n",
    "\n",
    "    Evaluates N+1 forward calls: one baseline plus one perturbed model per\n",
    "    layer. Step size is eps * max(1, |ln rho_j|) so the perturbation is\n",
    "    automatically scaled in log-resistivity space.\n",
    "    \"\"\"\n",
    "    fwd_kw = dict(use_numba=use_numba, use_cuda=use_cuda, transform=transform,\n",
    "                  hankel_filter=hankel_filter, fourier_filter=fourier_filter,\n",
    "                  euler_order=euler_order)\n",
    "    f0 = -fwd(thicknesses=thicknesses, resistivities=np.exp(log_resistivities),\n",
    "              tx_radius=tx_geom, times=times, **fwd_kw)\n",
    "    J = np.zeros((f0.size, log_resistivities.size))\n",
    "    for i in range(log_resistivities.size):\n",
    "        pert = log_resistivities.copy()\n",
    "        step = eps * max(1.0, abs(log_resistivities[i]))\n",
    "        pert[i] += step\n",
    "        fi = -fwd(thicknesses=thicknesses, resistivities=np.exp(pert),\n",
    "                  tx_radius=tx_geom, times=times, **fwd_kw)\n",
    "        valid = (f0 > 0) & (fi > 0)\n",
    "        J[valid, i] = (np.log(fi[valid]) - np.log(f0[valid])) / step\n",
    "    return J\n",
    "\n",
    "\n",
    "def getJ_analytical(thicknesses, log_resistivities, tx_radius, times,\n",
    "                    hankel_filter='key_101', fourier_filter='key_101'):\n",
    "    \"\"\"Analytical Jacobian d(ln(-dBdt_i)) / d(ln rho_j) for central-loop TEM.\n",
    "\n",
    "    For each time gate the DLF Fourier frequencies are looped over.  At each\n",
    "    frequency ``te_reflection_coeff_grad`` (pytem/recursion.py) returns both\n",
    "    the TE reflection coefficient r_TE(lambda) and its gradient\n",
    "    dr_TE/d(ln rho_j) for every layer j in a single forward+backward pass\n",
    "    through the Wait recursion — no extra forward calls per layer.\n",
    "\n",
    "    The frequency-domain sensitivities are then assembled with the same DLF\n",
    "    Hankel and Fourier filter weights used in the forward model, giving the\n",
    "    log-space Jacobian J_ij = d(ln(-dBdt_i)) / d(ln rho_j).\n",
    "    \"\"\"\n",
    "    thicknesses = np.asarray(thicknesses, dtype=float)\n",
    "    resistivities = np.exp(np.asarray(log_resistivities, dtype=float))\n",
    "    times = np.asarray(times, dtype=float)\n",
    "    n_lay = len(resistivities)\n",
    "    n_t = len(times)\n",
    "\n",
    "    h_base, _, h_j1 = HANKEL_FILTERS[hankel_filter]\n",
    "    f_base, f_sin, _ = FOURIER_FILTERS[fourier_filter]\n",
    "    n_f = len(f_base)\n",
    "\n",
    "    lam = h_base / float(tx_radius)   # (K,) horizontal wavenumbers\n",
    "\n",
    "    dbdt = np.zeros(n_t)\n",
    "    d_dbdt = np.zeros((n_lay, n_t))\n",
    "\n",
    "    for i in range(n_t):\n",
    "        hz = np.zeros(n_f, dtype=complex)\n",
    "        dhz = np.zeros((n_lay, n_f), dtype=complex)\n",
    "        for kf in range(n_f):\n",
    "            omega = f_base[kf] / times[i]\n",
    "            # Single forward+backward recursion pass per frequency\n",
    "            r_TE, dr_TE = te_reflection_coeff_grad(lam, omega, thicknesses, resistivities)\n",
    "            # Central-loop Hankel kernel: Hz = (1/2) sum_k r_TE_k * lam_k * h_j1_k\n",
    "            hz[kf] = 0.5 * np.dot(r_TE * lam, h_j1)\n",
    "            dhz[:, kf] = 0.5 * (dr_TE * lam[None, :] * h_j1[None, :]).sum(axis=1)\n",
    "        sig  = MU0 * np.imag(hz)\n",
    "        dsig = MU0 * np.imag(dhz)\n",
    "        dbdt[i]      = np.dot(sig, f_sin) / times[i]\n",
    "        d_dbdt[:, i] = dsig @ f_sin / times[i]\n",
    "\n",
    "    dbdt   *= (2.0 / np.pi)\n",
    "    d_dbdt *= (2.0 / np.pi)\n",
    "\n",
    "    # Log-space Jacobian: J_ij = d(ln(-dbdt_i)) / d(ln rho_j)\n",
    "    J = np.zeros((n_t, n_lay))\n",
    "    valid = dbdt < 0   # TEM step-off decay is negative\n",
    "    for j in range(n_lay):\n",
    "        J[valid, j] = d_dbdt[j, valid] / dbdt[valid]\n",
    "    return J\n",
    "\n",
    "\n",
    "# --- Private helpers used inside invert() ---\n",
    "\n",
    "def _gn_solve(Jw, dw, R, alpha_vector):\n",
    "    \"\"\"Solve the Gauss-Newton normal equations for one value of alpha.\n",
    "\n",
    "    Returns delta = (Jw^T Jw + A R)^{-1} Jw^T dw  where A = diag(alpha_vector).\n",
    "    \"\"\"\n",
    "    A   = np.diag(alpha_vector)\n",
    "    lhs = Jw.T @ Jw + A @ R\n",
    "    rhs = Jw.T @ dw\n",
    "    return np.linalg.solve(lhs, rhs)\n",
    "\n",
    "\n",
    "def _backtrack(m, delta, ln_rho_min, ln_rho_max):\n",
    "    \"\"\"Halve step size until the trial model is within resistivity bounds.\"\"\"\n",
    "    step = 1.0\n",
    "    for _ in range(10):\n",
    "        trial = m + step * delta\n",
    "        if np.all(trial >= ln_rho_min) and np.all(trial <= ln_rho_max):\n",
    "            return trial, step\n",
    "        step *= 0.5\n",
    "    return np.clip(m + step * delta, ln_rho_min, ln_rho_max), step\n",
    "\n",
    "\n",
    "def _alpha_search(alpha_start, alpha_steps, Jw, dw, R, m,\n",
    "                  thicknesses, fwd_fn, obs_data, w, ln_rho_min, ln_rho_max):\n",
    "    \"\"\"Line search over alpha: try all alpha_steps log-spaced values.\n",
    "\n",
    "    Evaluates all alpha_steps candidates and picks the one with minimum RMS.\n",
    "    Returns (alpha_hist, rms_hist, delta_hist) where each entry corresponds\n",
    "    to one trial alpha.\n",
    "    \"\"\"\n",
    "    alpha_hist, rms_hist, delta_hist = [], [], []\n",
    "    for i in range(alpha_steps):\n",
    "        alpha = getAlpha(alpha_start, step=i)\n",
    "        delta = _gn_solve(Jw, dw, R, getAlphas(alpha, thicknesses))\n",
    "        trial, step = _backtrack(m, delta, ln_rho_min, ln_rho_max)\n",
    "\n",
    "        mod   = fwd_fn(trial)\n",
    "        d_tri = np.log(obs_data) - np.log(mod)\n",
    "        rms   = np.sqrt(np.mean((w * d_tri) ** 2))\n",
    "\n",
    "        print(f\"    Alpha: {alpha:.2f},  RMS: {rms:.4f}\"\n",
    "              + (f\"  (step={step:.2f})\" if step < 1.0 else \"\"))\n",
    "\n",
    "        alpha_hist.append(alpha)\n",
    "        rms_hist.append(rms)\n",
    "        delta_hist.append(trial - m)\n",
    "\n",
    "    return alpha_hist, rms_hist, delta_hist\n"
   ]
