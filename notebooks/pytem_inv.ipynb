    "def dbdt_to_apprho(obs_data, tx_area, times):\n",
    "    \"\"\"Convert dB/dt to apparent resistivity.\"\"\"\n",
    "    M = tx_area\n",
    "    term = (2 * MU0 * M) / (5 * times * obs_data)\n",
    "    app_rho = (MU0 / (4 * np.pi * times)) * (term ** (2 / 3))\n",
    "    return app_rho"
   ]
  },
